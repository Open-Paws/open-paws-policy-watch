# Open States API — free tier, get key at openstates.org/api/
OPENSTATES_API_KEY=

# OpenRouter — routes to cheapest capable model
# Get key at openrouter.ai
OPENROUTER_API_KEY=

# LLM provider (default: openrouter)
LLM_PROVIDER=openrouter

# Telegram bot token for coalition alerts
TELEGRAM_BOT_TOKEN=

# Database path (SQLite for dev, Postgres URL for production)
DATABASE_PATH=./policy_watch.db
# DATABASE_URL=postgresql://user:pass@localhost/policy_watch
